<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    # Sudah di /public/: jangan rewrite lagi.
    RewriteCond %{REQUEST_URI} !^/public/

    # File/folder nyata di root (mis. index.php) tetap dilayani di sini.
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d

    RewriteRule ^(.*)$ public/$1 [L,QSA]
</IfModule>

<IfModule mod_dir.c>
    DirectoryIndex index.php index.html
</IfModule>

<IfModule mod_authz_core.c>
    <FilesMatch "^\.env">
        Require all denied
    </FilesMatch>
</IfModule>
<IfModule !mod_authz_core.c>
    <FilesMatch "^\.env">
        Order deny,allow
        Deny from all
    </FilesMatch>
</IfModule>
